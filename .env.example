# Paperclip Environment Variables for Railway
# Copy this to Railway's environment variables dashboard

# === Required: Database ===
# Railway will auto-provide these when you add PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:port/database

# === Required: JWT Secret ===
# Generate with: openssl rand -hex 32
PAPERCLIP_AGENT_JWT_SECRET=your-jwt-secret-here

# === Required: GitHub Integration ===
# Create token at: https://github.com/settings/tokens/new
# Scopes needed: repo, project, write:discussion
GITHUB_TOKEN=ghp_your_github_token_here

# === Optional: Slack Plugin Secrets ===
# These can also be configured via Paperclip UI after deployment
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# === Optional: Storage (S3) ===
# Leave blank to use Railway's persistent volumes
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# === Optional: Email (for notifications) ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# === Optional: Sentry Error Tracking ===
# SENTRY_DSN=https://your-sentry-dsn

# === Optional: OpenAI API (if using custom models) ===
# OPENAI_API_KEY=sk-your-openai-key
